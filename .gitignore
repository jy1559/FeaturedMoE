# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.venv/
venv/

# Logs/temp
*.log
*.tmp
*.swp

# Large datasets (exclude all local data)
Datasets/

# Experiment artifacts and caches
experiments/saved/
experiments/outputs/
experiments/log_tensorboard/
experiments/wandb/
experiments/_quarantine/
experiments/run/log/

# Keep experiment artifacts for backup; ignore only clearly transient internals.
experiments/run/artifacts/tmp/
experiments/run/artifacts/**/__pycache__/
experiments/run/artifacts/**/.ipynb_checkpoints/
experiments/run/artifacts/**/.DS_Store

# Keep run logs/results even with global log ignore.
!experiments/run/artifacts/**/*.log
!experiments/run/artifacts/**/*.txt
!experiments/run/artifacts/**/*.out
!experiments/run/hyperopt_results/**/*.log

# Common model/checkpoint binaries
*.pth
*.pt
*.ckpt
*.bin
*.npz
*.npy

# Local Codex metadata/logs
.codex/

# Local secrets
experiments/run/baseline/.env.slack
experiments/run/baseline_2/.env.slack
experiments/run/fmoe_n3/.env.slack
