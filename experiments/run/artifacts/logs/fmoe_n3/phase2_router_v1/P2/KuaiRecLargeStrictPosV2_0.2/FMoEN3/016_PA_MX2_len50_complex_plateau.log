[PHASE2_COMBO_HEADER]
combo_id=PA_MX2 family=A role=mix desc=len50_complex_plateau
dataset=KuaiRecLargeStrictPosV2_0.2 gpu=6 launch_group=4 launch_order=4
launch_max_evals=10 cli_max_evals=0
tune_epochs=100 tune_patience=10 seed=9915
runtime_bucket=heavy est_50ep_single_eval_min=80.4

[PURPOSE]
- len50_complex_plateau | family=A | role=mix

[KEY_CHANGES_VS_DEFAULT]
- max_seq_length=50 (base=20)
- train_batch_size=1536 (base=4096)
- stage_feature_encoder_mode={"macro": "complex", "micro": "complex", "mid": "complex"} (base={"macro": "linear", "micro": "linear", "mid": "linear"})
- stage_feature_family_mask={} (base=None)
- macro_history_window=10 (base=5)
- lr_scheduler_type=plateau (base=warmup_cosine)

[FIXED_SETTINGS]
- feature_mode=full_v3
- MAX_ITEM_LIST_LENGTH=50
- train_batch_size=1536
- eval_batch_size=3072
- embedding_size=128
- d_ff=256
- num_heads=4
- attn_dropout_prob=0.1
- d_feat_emb=16
- d_expert_hidden=128
- d_router_hidden=64
- expert_scale=3
- layer_layout=["macro", "mid", "micro"]
- stage_feature_encoder_mode={"macro": "complex", "micro": "complex", "mid": "complex"}
- stage_compute_mode={"macro": "moe", "micro": "moe", "mid": "moe"}
- stage_router_mode={"macro": "learned", "micro": "learned", "mid": "learned"}
- stage_router_source={"macro": "both", "micro": "both", "mid": "both"}
- stage_feature_injection={"macro": "none", "micro": "none", "mid": "none"}
