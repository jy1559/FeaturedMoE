[PHASE2_COMBO_HEADER]
combo_id=PD11 family=D role=group_reg desc=factored_strong_group_balance
dataset=KuaiRecLargeStrictPosV2_0.2 gpu=7 launch_group=10 launch_order=10
launch_max_evals=15 cli_max_evals=0
tune_epochs=100 tune_patience=10 seed=9938
runtime_bucket=medium-heavy est_50ep_single_eval_min=55.4

[PURPOSE]
- factored_strong_group_balance | family=D | role=group_reg

[KEY_CHANGES_VS_DEFAULT]
- stage_router_type={"macro": "factored", "micro": "factored", "mid": "factored"} (base={"macro": "standard", "micro": "standard", "mid": "standard"})
- stage_feature_family_mask={} (base=None)
- balance_loss_lambda=0.006 (base=0.004)
- factored_group_balance_lambda=0.01 (base=0.0)

[FIXED_SETTINGS]
- feature_mode=full_v3
- MAX_ITEM_LIST_LENGTH=20
- train_batch_size=4096
- eval_batch_size=4096
- embedding_size=128
- d_ff=256
- num_heads=4
- attn_dropout_prob=0.1
- d_feat_emb=16
- d_expert_hidden=128
- d_router_hidden=64
- expert_scale=3
- layer_layout=["macro", "mid", "micro"]
- stage_feature_encoder_mode={"macro": "linear", "micro": "linear", "mid": "linear"}
- stage_compute_mode={"macro": "moe", "micro": "moe", "mid": "moe"}
- stage_router_mode={"macro": "learned", "micro": "learned", "mid": "learned"}
- stage_router_source={"macro": "both", "micro": "both", "mid": "both"}
- stage_feature_injection={"macro": "none", "micro": "none", "mid": "none"}
- stage_router_type={"macro": "factored", "micro": "factored", "mid": "factored"}
- stage_router_granularity={"macro": "session", "micro": "token", "mid": "session"}
- stage_feature_family_mask={}
- macro_history_window=5
- moe_top_k=0
- balance_loss_lambda=0.006
- z_loss_lambda=0.0001
- gate_entropy_lambda=0.0
- rule_agreement_lambda=0.0
- group_coverage_lambda=0.0
- group_prior_align_lambda=0.0
- feature_group_bias_lambda=0.0
- feature_group_prior_temperature=1.0
- factored_group_balance_lambda=0.01
- gate_entropy_until=0.0
- lr_scheduler_type=warmup_cosine
- lr_scheduler_warmup_ratio=0.1
- lr_scheduler_min_lr_ratio=0.1
- lr_scheduler_plateau_factor=0.5
- lr_scheduler_plateau_patience=3

[SEARCH_SPACE]
- learning_rate=loguniform[0.00015, 0.01]
- hidden_dropout_prob=choice[0.1, 0.15, 0.2, 0.25]
- weight_decay=choice[0.0, 1e-07, 1e-06, 5e-05, 0.0001]
- lr_scheduler_type=choice[warmup_cosine]

[COMMAND]
- /venv/FMoE/bin/python hyperopt_tune.py --config-name config --max-evals 15 --tune-epochs 100 --tune-patience 10 --seed 9938 --run-group fmoe_n3 --run-axis phase2_router_v1 --run-phase PD11 model=featured_moe_n3_tune dataset=KuaiRecLargeStrictPosV2_0.2 eval_mode=session feature_mode=full_v3 gpu_id=7 log_wandb=false enable_tf32=true fmoe_debug_logging=false fmoe_diag_logging=true fmoe_eval_logging_timing=final_only fmoe_feature_ablation_logging=false fmoe_special_logging=true MAX_ITEM_LIST_LENGTH=20 train_batch_size=4096 eval_batch_size=4096 embedding_size=128 num_heads=4 attn_dropout_prob=0.1 d_ff=256 d_feat_emb=16 d_expert_hidden=128 d_router_hidden=64 expert_scale=3 ++layer_layout=["macro","mid","micro"] ++stage_feature_encoder_mode={macro:"linear",mid:"linear",micro:"linear"} ++stage_compute_mode={macro:"moe",mid:"moe",micro:"moe"} ++stage_router_mode={macro:"learned",mid:"learned",micro:"learned"} ++stage_router_source={macro:"both",mid:"both",micro:"both"} ++stage_feature_injection={macro:"none",mid:"none",micro:"none"} ++stage_router_type={macro:"factored",mid:"factored",micro:"factored"} ++stage_router_granularity={macro:"session",mid:"session",micro:"token"} ++stage_feature_family_mask={} macro_history_window=5 moe_top_k=0 moe_top_k_policy=auto moe_top_k_ratio=0.5 macro_session_pooling=mean balance_loss_lambda=0.006 z_loss_lambda=0.0001 gate_entropy_lambda=0.0 gate_entropy_until=0.0 rule_agreement_lambda=0.0 group_coverage_lambda=0.0 group_prior_align_lambda=0.0 feature_group_bias_lambda=0.0 feature_group_prior_temperature=1.0 factored_group_balance_lambda=0.01 lr_scheduler_type=warmup_cosine lr_scheduler_warmup_ratio=0.1 lr_scheduler_min_lr_ratio=0.1 lr_scheduler_plateau_factor=0.5 lr_scheduler_plateau_patience=3 ++combo_family="D" ++combo_role="group_reg" ++combo_desc="factored_strong_group_balance" ++search.learning_rate=[0.00015,0.01] ++search.weight_decay=[0.0,1e-07,1e-06,5e-05,0.0001] ++search.hidden_dropout_prob=[0.1,0.15,0.2,0.25] ++search.lr_schedu